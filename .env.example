# ------------------------------------------------------------------
# CloudynHost — environment variables
# Copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------------

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://cloudynhost:cloudynhost@localhost:5432/cloudynhost?schema=public"

# --- Auth (custom JWT sessions) ---
# Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-please-generate-a-long-random-secret"
# Session lifetime in days
AUTH_SESSION_DAYS=30

# --- Credential encryption (AES-256-GCM) ---
# Must be 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="change-me-32-byte-base64-key-aaaaaaaaaaaaaaa="

# --- Stripe (TEST MODE) ---
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# From `stripe listen` output, or dashboard webhook signing secret
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# When true, the app uses seeded placeholder Stripe price ids so checkout UI
# works without real Stripe products. Set false once you've run stripe:sync.
STRIPE_PLACEHOLDER_MODE=true

# ------------------------------------------------------------------
# Email — choose ONE transport. Resend is used if RESEND_API_KEY is set,
# otherwise SMTP. Verify the active transport at /admin/email or `npm run email:test`.
# ------------------------------------------------------------------
# From address used for all transactional email. Use a domain you control
# (verified in Resend / your SMTP provider) in production.
EMAIL_FROM="CloudynHost <no-reply@cloudynhost.com>"

# --- Option A: Resend (recommended for production) ---
# Create a key at https://resend.com/api-keys and verify your sending domain.
# When set, this takes priority over SMTP below.
RESEND_API_KEY=

# --- Option B: SMTP ---
# Local dev defaults below target Mailpit (docker compose up -d) — no real
# credentials needed; view captured email at http://localhost:8025.
# For production SMTP (e.g. Postmark, SES, Mailgun): set host/port/user/pass and
# SMTP_SECURE=true for port 465 (false for 587/STARTTLS).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- Provisioning ---
# Default provider for new services: mock | hetzner | digitalocean | vultr
DEFAULT_CLOUD_PROVIDER=mock

# --- Worker / cron ---
# Shared secret to authorize /api/cron/* and /api/worker/* invocations
CRON_SECRET="change-me-cron-secret"
